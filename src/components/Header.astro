---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="sticky top-0 z-50 bg-white/80 backdrop-blur border-b border-slate-100">
	<nav class="max-w-4xl mx-auto px-6 h-16 flex items-center justify-between">
		<a href="/" class="font-bold tracking-tight text-slate-900 hover:text-blue-600 transition-colors">{SITE_TITLE}</a>
		<div class="hidden md:flex items-center gap-2">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/projects">项目</HeaderLink>
			<HeaderLink href="/blog">博客</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
			<HeaderLink href="/contact">联系</HeaderLink>
		</div>
		<div class="hidden md:flex items-center gap-3">
			<a href="https://github.com/jklop3841" target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-slate-900 transition-colors text-sm font-medium">GitHub</a>
			<a href="https://x.com/wromsheep" target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-slate-900 transition-colors text-sm font-medium">X</a>
		</div>
		<a href="/links" class="md:hidden inline-flex items-center px-4 py-2 rounded-full bg-slate-900 text-white text-sm font-semibold hover:bg-slate-800 transition-colors">
			Links
		</a>
	</nav>
</header>
