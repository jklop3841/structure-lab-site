---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`Projects | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-white text-slate-900">
		<Header />
		<main class="max-w-4xl mx-auto px-6 py-12 space-y-12">
			<header class="space-y-3">
				<h1 class="text-3xl md:text-4xl font-bold tracking-tight">项目</h1>
				<p class="text-slate-600">
					这里展示我做过的一些项目与作品。你可以先看重点案例，再决定是否联系我。
				</p>
			</header>

			<section class="grid grid-cols-1 md:grid-cols-2 gap-6">
				{[1, 2, 3, 4].map((i) => (
					<article class="group rounded-2xl border border-slate-100 bg-slate-50 p-6 hover:bg-white hover:border-blue-200 hover:shadow-xl hover:shadow-blue-500/5 transition-all">
						<h2 class="text-lg font-bold text-slate-900">项目名称 0{i}</h2>
						<p class="mt-2 text-slate-600">
							一句话说明项目解决了什么问题、带来了什么结果。
						</p>
						<div class="mt-4 flex flex-wrap gap-2">
							<span class="px-2 py-1 bg-white border border-slate-200 text-xs text-slate-500 rounded-md">Case</span>
							<span class="px-2 py-1 bg-white border border-slate-200 text-xs text-slate-500 rounded-md">Automation</span>
						</div>
						<div class="mt-5">
							<a href="#" class="text-sm font-medium text-blue-600 hover:underline">查看详情 →</a>
						</div>
					</article>
				))}
			</section>

			<section class="rounded-3xl border border-slate-100 p-8 bg-white">
				<h2 class="text-xl font-bold">想一起做点东西？</h2>
				<p class="mt-2 text-slate-600">如果你有明确目标或正在寻找合作者，可以直接发邮件给我。</p>
				<div class="mt-5">
					<a href="/contact" class="inline-flex items-center px-6 py-3 rounded-full bg-slate-900 text-white font-medium hover:bg-slate-800 transition-colors">
						联系我
					</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>


