---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="text-[color:var(--color-text)] selection:bg-amber-500/20">
		<main class="max-w-6xl mx-auto px-6 md:px-10 py-12 md:py-20 space-y-16">

			<!-- Top Profile + Contacts -->
			<header class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
				<div class="lg:col-span-7 flex gap-6">
					<div class="shrink-0">
						<div class="relative w-20 h-20 md:w-24 md:h-24 rounded-2xl overflow-hidden border border-white/10 bg-[color:var(--color-surface)] shadow-[var(--shadow-glow)]">
							<img src="/avatar.jpg" alt="头像" class="w-full h-full object-cover" loading="eager" />
							<div class="pointer-events-none absolute inset-0 ring-1 ring-[color:rgba(214,178,94,0.22)]"></div>
						</div>
					</div>
					<div class="space-y-2">
						<h1 class="text-3xl md:text-4xl font-bold tracking-tight text-white">
							AI智能体 | 卢成
						</h1>
						<p class="text-sm md:text-base text-white/65">
							江苏 · 苏州
						</p>
						<p class="text-base md:text-lg text-white/75 leading-relaxed max-w-xl">
							专注 AI Agent / 自动化工作流 / 结构化内容系统。用工程化的方法把复杂问题拆解成可执行的系统，并持续交付可复用资产。
						</p>
						<div class="pt-3 flex flex-col sm:flex-row gap-3">
							<a href="/projects" class="inline-flex items-center justify-center px-6 py-3 rounded-[var(--radius-button)] bg-[color:var(--color-gold)] text-black font-bold hover:brightness-110 transition">
								查看项目
							</a>
							<a href="/blog" class="inline-flex items-center justify-center px-6 py-3 rounded-[var(--radius-button)] border border-white/15 bg-white/5 text-white font-semibold hover:bg-white/10 transition">
								读博客
							</a>
						</div>
					</div>
				</div>

				<aside class="lg:col-span-5 space-y-3">
					<div class="text-xs font-bold tracking-[0.24em] uppercase text-white/45">联系 / Links</div>

					<a href="https://x.com/wromsheep" target="_blank" rel="noopener noreferrer" class="group flex items-center justify-between gap-4 rounded-2xl border border-white/10 bg-white/5 px-5 py-4 hover:bg-white/10 transition">
						<div class="space-y-1">
							<div class="text-white font-semibold">X / Twitter</div>
							<div class="text-white/55 text-sm">@wromsheep</div>
						</div>
						<div class="text-[color:var(--color-gold)] group-hover:translate-x-0.5 transition">→</div>
					</a>

					<a href="https://github.com/jklop3841" target="_blank" rel="noopener noreferrer" class="group flex items-center justify-between gap-4 rounded-2xl border border-white/10 bg-white/5 px-5 py-4 hover:bg-white/10 transition">
						<div class="space-y-1">
							<div class="text-white font-semibold">GitHub</div>
							<div class="text-white/55 text-sm">jklop3841</div>
						</div>
						<div class="text-[color:var(--color-gold)] group-hover:translate-x-0.5 transition">→</div>
					</a>

					<a href="mailto:jklop3841@gmail.com" class="group flex items-center justify-between gap-4 rounded-2xl border border-white/10 bg-white/5 px-5 py-4 hover:bg-white/10 transition">
						<div class="space-y-1">
							<div class="text-white font-semibold">Gmail</div>
							<div class="text-white/55 text-sm">jklop3841@gmail.com</div>
						</div>
						<div class="text-[color:var(--color-gold)] group-hover:translate-x-0.5 transition">→</div>
					</a>

					<button id="wechat-open" class="group w-full text-left flex items-center justify-between gap-4 rounded-2xl border border-white/10 bg-white/5 px-5 py-4 hover:bg-white/10 transition">
						<div class="space-y-1">
							<div class="text-white font-semibold">WeChat</div>
							<div class="text-white/55 text-sm">扫码添加好友</div>
						</div>
						<div class="text-[color:var(--color-gold)] group-hover:translate-x-0.5 transition">→</div>
					</button>
				</aside>
			</header>

			<!-- Projects Grid -->
			<section class="space-y-6">
				<div class="flex items-center gap-4">
					<h2 class="text-lg md:text-xl font-bold text-white">产品 / 项目</h2>
					<div class="flex-1 h-px bg-white/10"></div>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
					{[1, 2, 3, 4, 5].map((i) => (
						<article class="group relative rounded-[var(--radius-card)] border border-white/10 bg-[color:var(--color-surface)] p-6 shadow-[var(--shadow-glow)] hover:border-[color:rgba(214,178,94,0.35)] transition">
							<div class="absolute inset-0 rounded-[var(--radius-card)] opacity-0 group-hover:opacity-100 transition pointer-events-none" style="background: radial-gradient(600px 200px at 20% 0%, rgba(214,178,94,0.12), transparent 60%), radial-gradient(400px 200px at 80% 20%, rgba(245,158,11,0.12), transparent 65%);"></div>
							<div class="relative space-y-3">
								<div class="text-xs font-bold tracking-[0.22em] uppercase text-white/45">Module 0{i}</div>
								<h3 class="text-white font-bold text-lg">高端科技项目占位 0{i}</h3>
								<p class="text-white/60 text-sm leading-relaxed">
									一句话描述：解决什么关键问题、产生什么可量化价值（效率/成本/增长）。
								</p>
								<div class="flex flex-wrap gap-2 pt-2">
									<span class="text-xs px-2 py-1 rounded-full border border-white/10 bg-white/5 text-white/70">AI Agent</span>
									<span class="text-xs px-2 py-1 rounded-full border border-white/10 bg-white/5 text-white/70">Automation</span>
								</div>
								<div class="pt-3">
									<a href="/projects" class="inline-flex items-center gap-2 text-sm font-semibold text-[color:var(--color-gold)] hover:brightness-110 transition">
										查看详情 <span class="opacity-80">→</span>
									</a>
								</div>
							</div>
						</article>
					))}
				</div>
			</section>

			<!-- Blog Feed -->
			<section class="space-y-6">
				<div class="flex items-center gap-4">
					<h2 class="text-lg md:text-xl font-bold text-white">近期思考</h2>
					<div class="flex-1 h-px bg-white/10"></div>
				</div>
				<div class="rounded-[var(--radius-card)] border border-white/10 bg-white/5 overflow-hidden">
					{posts.map((post, idx) => (
						<a href={`/blog/${post.id}/`} class={`block px-6 py-5 hover:bg-white/5 transition ${idx ? 'border-t border-white/10' : ''}`}>
							<div class="flex items-start justify-between gap-6">
								<div class="space-y-1">
									<div class="text-white font-semibold">{post.data.title}</div>
									<div class="text-white/55 text-sm">{post.data.description}</div>
								</div>
								<time class="text-white/40 text-xs tabular-nums shrink-0">
									<FormattedDate date={post.data.pubDate} />
								</time>
							</div>
						</a>
					))}
				</div>
			</section>

		</main>

		<Footer />

		<!-- WeChat Modal -->
		<div id="wechat-modal" class="fixed inset-0 hidden items-center justify-center bg-black/70 p-6">
			<div class="w-full max-w-sm rounded-2xl border border-white/10 bg-[color:var(--color-surface)] shadow-[var(--shadow-glow)] p-6">
				<div class="flex items-start justify-between gap-4">
					<div class="space-y-1">
						<div class="text-white font-bold">WeChat</div>
						<div class="text-white/55 text-sm">扫码添加好友</div>
					</div>
					<button id="wechat-close" class="text-white/60 hover:text-white transition">✕</button>
				</div>
				<div class="mt-5 rounded-xl overflow-hidden border border-white/10 bg-black/20">
					<img src="/wechat-qr.jpg" alt="WeChat 二维码" class="w-full h-auto" loading="lazy" />
				</div>
				<div class="mt-4 text-center text-white/55 text-sm">微信：jklop3841</div>
			</div>
		</div>

		<script>
			const openBtn = document.getElementById('wechat-open');
			const modal = document.getElementById('wechat-modal');
			const closeBtn = document.getElementById('wechat-close');
			openBtn?.addEventListener('click', () => {
				modal?.classList.remove('hidden');
				modal?.classList.add('flex');
			});
			closeBtn?.addEventListener('click', () => {
				modal?.classList.add('hidden');
				modal?.classList.remove('flex');
			});
			modal?.addEventListener('click', (e) => {
				if (e.target === modal) {
					modal.classList.add('hidden');
					modal.classList.remove('flex');
				}
			});
		</script>
	</body>
</html>

			<!-- Featured Projects Preview (Placeholder) -->
			<section class="space-y-8">
				<div class="flex items-baseline justify-between">
					<h2 class="text-2xl font-bold text-slate-900">精选项目</h2>
					<a href="/projects" class="text-sm font-medium text-blue-600 hover:underline">全部项目 &rarr;</a>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
					{[1, 2].map((i) => (
						<div class="group relative bg-slate-50 rounded-2xl p-8 border border-slate-100 hover:border-blue-200 hover:bg-white hover:shadow-xl hover:shadow-blue-500/5 transition-all">
							<div class="space-y-4">
								<div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center text-blue-600 group-hover:scale-110 transition-transform">
									<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
									</svg>
								</div>
								<h3 class="text-xl font-bold text-slate-900">项目名称 0{i}</h3>
								<p class="text-slate-600 leading-relaxed">
									这里是项目的简短描述，介绍你在这个项目中解决的核心问题和使用的技术栈。
								</p>
								<div class="flex gap-2">
									<span class="px-2 py-1 bg-white border border-slate-200 text-xs text-slate-500 rounded-md">Next.js</span>
									<span class="px-2 py-1 bg-white border border-slate-200 text-xs text-slate-500 rounded-md">Tailwind</span>
								</div>
							</div>
						</div>
					))}
				</div>
			</section>

			<!-- Latest Blog Posts -->
			<section class="space-y-8">
				<div class="flex items-baseline justify-between">
					<h2 class="text-2xl font-bold text-slate-900">最新思考</h2>
					<a href="/blog" class="text-sm font-medium text-blue-600 hover:underline">阅读博客 &rarr;</a>
				</div>
				<div class="space-y-4">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="block group p-6 rounded-2xl hover:bg-slate-50 transition-colors border border-transparent hover:border-slate-100">
							<div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
								<div class="space-y-1">
									<h3 class="text-lg font-bold text-slate-900 group-hover:text-blue-600 transition-colors">
										{post.data.title}
									</h3>
									<p class="text-slate-500 text-sm line-clamp-1">{post.data.description}</p>
								</div>
								<time class="text-sm text-slate-400 tabular-nums shrink-0">
									<FormattedDate date={post.data.pubDate} />
								</time>
							</div>
						</a>
					))}
				</div>
			</section>

			<!-- Contact CTA -->
			<section class="bg-blue-600 rounded-3xl p-8 md:p-12 text-center space-y-6">
				<h2 class="text-3xl font-bold text-white">准备好开始合作了吗？</h2>
				<p class="text-blue-100 max-w-lg mx-auto text-lg">
					无论是项目咨询、技术交流，还是单纯想打个招呼，我都非常欢迎。
				</p>
				<div class="pt-4">
					<a href="mailto:contact@structure-lab.pages.dev" class="inline-flex items-center gap-2 px-8 py-4 bg-white text-blue-600 font-bold rounded-full hover:bg-blue-50 transition-colors shadow-lg">
						发送邮件
						<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor">
							<path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
							<path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
						</svg>
					</a>
				</div>
			</section>

		</main>
		<Footer />
	</body>
</html>
