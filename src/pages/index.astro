---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-[#07080a] text-[#e7e7e7] selection:bg-amber-500/20 antialiased">
		
		<main class="max-w-6xl mx-auto px-6 md:px-10 py-12 md:py-24 space-y-20">
			
			<!-- Top Profile + Contacts Section -->
			<header class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
				<div class="lg:col-span-7 flex flex-col sm:flex-row gap-8">
					<!-- Avatar Container -->
					<div class="shrink-0">
						<div class="relative w-24 h-24 md:w-32 md:h-32 rounded-3xl overflow-hidden border border-white/10 bg-[#0c0e12] shadow-[0_0_0_1px_rgba(214,178,94,0.16),0_24_64px_rgba(0,0,0,0.6)]">
							<img src="/avatar.jpg" alt="卢成" class="w-full h-full object-cover" loading="eager" />
							<div class="pointer-events-none absolute inset-0 ring-1 ring-inset ring-amber-500/20"></div>
						</div>
					</div>
					<!-- Bio Area -->
					<div class="space-y-4">
						<div class="space-y-1">
							<h1 class="text-3xl md:text-5xl font-bold tracking-tight text-white">
								AI智能体 | 卢成
							</h1>
							<p class="text-amber-500/80 font-medium tracking-wide">江苏 · 苏州</p>
						</div>
						<p class="text-lg md:text-xl text-white/70 leading-relaxed max-w-xl">
							专注 AI Agent / 自动化工作流 / 结构化内容系统。用工程化的方法把复杂问题拆解成可执行的系统，并持续交付可复用资产。
						</p>
						<div class="pt-4 flex flex-wrap gap-4">
							<a href="/projects" class="px-8 py-3 rounded-xl bg-amber-500 text-black font-bold hover:bg-amber-400 transition-all shadow-[0_0_20px_rgba(245,158,11,0.3)]">
								查看项目成果
							</a>
							<a href="/blog" class="px-8 py-3 rounded-xl border border-white/10 bg-white/5 text-white font-semibold hover:bg-white/10 transition-all">
								深度思考
							</a>
						</div>
					</div>
				</div>

				<!-- Contact Links Area -->
				<aside class="lg:col-span-5 grid grid-cols-1 gap-3">
					<div class="text-[10px] font-black uppercase tracking-[0.3em] text-white/30 mb-1">CONNECT / CONTACT</div>
					
					<a href="https://x.com/wromsheep" target="_blank" rel="noopener noreferrer" class="group flex items-center justify-between p-4 rounded-2xl border border-white/5 bg-white/[0.03] hover:bg-white/[0.08] hover:border-amber-500/30 transition-all">
						<div class="flex items-center gap-4">
							<div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-white/40 group-hover:text-amber-500 transition-colors">𝕏</div>
							<div>
								<div class="text-sm font-bold text-white">Twitter / X</div>
								<div class="text-xs text-white/40">@wromsheep</div>
							</div>
						</div>
						<span class="text-amber-500/50 group-hover:translate-x-1 transition-transform">→</span>
					</a>

					<a href="https://github.com/jklop3841" target="_blank" rel="noopener noreferrer" class="group flex items-center justify-between p-4 rounded-2xl border border-white/5 bg-white/[0.03] hover:bg-white/[0.08] hover:border-amber-500/30 transition-all">
						<div class="flex items-center gap-4">
							<div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-white/40 group-hover:text-amber-500 transition-colors">GH</div>
							<div>
								<div class="text-sm font-bold text-white">GitHub</div>
								<div class="text-xs text-white/40">jklop3841</div>
							</div>
						</div>
						<span class="text-amber-500/50 group-hover:translate-x-1 transition-transform">→</span>
					</a>

					<a href="mailto:jklop3841@gmail.com" class="group flex items-center justify-between p-4 rounded-2xl border border-white/5 bg-white/[0.03] hover:bg-white/[0.08] hover:border-amber-500/30 transition-all">
						<div class="flex items-center gap-4">
							<div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-white/40 group-hover:text-amber-500 transition-colors">@</div>
							<div>
								<div class="text-sm font-bold text-white">Gmail</div>
								<div class="text-xs text-white/40">jklop3841@gmail.com</div>
							</div>
						</div>
						<span class="text-amber-500/50 group-hover:translate-x-1 transition-transform">→</span>
					</a>

					<button id="wechat-trigger" class="group w-full flex items-center justify-between p-4 rounded-2xl border border-white/5 bg-white/[0.03] hover:bg-white/[0.08] hover:border-amber-500/30 transition-all cursor-pointer">
						<div class="flex items-center gap-4">
							<div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-white/40 group-hover:text-amber-500 transition-colors">WX</div>
							<div>
								<div class="text-sm font-bold text-white">WeChat</div>
								<div class="text-xs text-white/40">扫码建立连接</div>
							</div>
						</div>
						<span class="text-amber-500/50 group-hover:translate-x-1 transition-transform">→</span>
					</button>
				</aside>
			</header>

			<!-- Products / Projects Grid -->
			<section class="space-y-10">
				<div class="flex items-center gap-6">
					<h2 class="text-xl md:text-2xl font-bold text-white tracking-tight">产品 & 项目集成</h2>
					<div class="flex-1 h-px bg-gradient-to-r from-white/10 to-transparent"></div>
				</div>
				
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					{[1, 2, 3, 4, 5].map((i) => (
						<article class="group relative p-8 rounded-3xl border border-white/5 bg-[#0c0e12] hover:border-amber-500/30 transition-all overflow-hidden shadow-2xl">
							<div class="absolute inset-0 bg-gradient-to-br from-amber-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
							<div class="relative space-y-4">
								<div class="text-[10px] font-black text-white/20 tracking-widest uppercase">MODULE 0{i}</div>
								<h3 class="text-xl font-bold text-white group-hover:text-amber-400 transition-colors">前卫科技项目 0{i}</h3>
								<p class="text-white/50 text-sm leading-relaxed">
									专注于[此处填入领域]的自动化解决方案，通过[技术手段]实现[具体价值]。
								</p>
								<div class="flex gap-2 pt-2">
									<span class="text-[10px] px-2 py-1 rounded-md border border-white/10 bg-white/5 text-white/40">AI AGENT</span>
									<span class="text-[10px] px-2 py-1 rounded-md border border-white/10 bg-white/5 text-white/40">AUTOMATION</span>
								</div>
							</div>
						</article>
					))}
					<!-- Empty Slot for Placeholder -->
					<div class="border border-dashed border-white/10 rounded-3xl p-8 flex items-center justify-center bg-white/[0.01]">
						<span class="text-white/20 text-xs font-bold tracking-widest italic uppercase">Initializing...</span>
					</div>
				</div>
			</section>

			<!-- Recent Thoughts Feed -->
			<section class="space-y-8">
				<div class="flex items-center gap-6">
					<h2 class="text-xl md:text-2xl font-bold text-white tracking-tight">近期思考</h2>
					<div class="flex-1 h-px bg-gradient-to-r from-white/10 to-transparent"></div>
				</div>
				<div class="rounded-3xl border border-white/5 bg-white/[0.02] divide-y divide-white/5 overflow-hidden text-sm">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="group block px-8 py-6 hover:bg-white/[0.04] transition-all">
							<div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
								<div class="space-y-1">
									<h4 class="font-bold text-white group-hover:text-amber-400 transition-colors text-base">{post.data.title}</h4>
									<p class="text-white/40 line-clamp-1">{post.data.description}</p>
								</div>
								<time class="text-white/20 tabular-nums font-medium shrink-0">
									<FormattedDate date={post.data.pubDate} />
								</time>
							</div>
						</a>
					))}
				</div>
			</section>

		</main>

		<Footer />

		<!-- WeChat Modal Overlay -->
		<div id="wechat-modal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/90 backdrop-blur-sm p-6">
			<div class="w-full max-w-sm rounded-3xl border border-white/10 bg-[#0c0e12] p-8 shadow-[0_0_80px_rgba(0,0,0,1)]">
				<div class="flex items-center justify-between mb-6">
					<h3 class="text-xl font-bold text-white tracking-tight">WeChat 连接</h3>
					<button id="wechat-close" class="text-white/40 hover:text-white transition-colors">✕</button>
				</div>
				<div class="aspect-square rounded-2xl border border-white/5 bg-black/40 overflow-hidden shadow-inner p-2">
					<img src="/wechat-qr.jpg" alt="WeChat QR" class="w-full h-full object-contain" />
				</div>
				<div class="mt-6 text-center space-y-2">
					<div class="text-amber-500 font-bold tracking-widest text-sm uppercase">扫码添加好友</div>
					<div class="text-white/40 text-xs font-medium">微信 ID: jklop3841</div>
				</div>
			</div>
		</div>

		<script>
			const modal = document.getElementById('wechat-modal');
			document.getElementById('wechat-trigger')?.addEventListener('click', () => {
				modal?.classList.remove('hidden');
				modal?.classList.add('flex');
			});
			document.getElementById('wechat-close')?.addEventListener('click', () => {
				modal?.classList.add('hidden');
				modal?.classList.remove('flex');
			});
			modal?.addEventListener('click', (e) => {
				if (e.target === modal) {
					modal.classList.add('hidden');
					modal.classList.remove('flex');
				}
			});
		</script>
	</body>
</html>
