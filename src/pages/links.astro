---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`快速连接 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<meta name="robots" content="noindex, follow" />
	</head>
	<body class="bg-white text-slate-900">
		<Header />
		<main class="max-w-xl mx-auto px-6 py-12 space-y-12">
			<header class="text-center space-y-4">
				<h1 class="text-3xl md:text-4xl font-bold tracking-tight">Structure Lab</h1>
				<p class="text-slate-600 text-lg">
					结构化思维 × 技术执行。把复杂事变简单，把内容变资产。
				</p>
				<div class="pt-2">
					<a href="/projects" class="inline-flex items-center justify-center w-full px-6 py-4 rounded-full bg-slate-900 text-white font-bold hover:bg-slate-800 transition-colors">
						进入主站（作品/博客）
					</a>
				</div>
			</header>

			<section class="space-y-4">
				<h2 class="text-sm font-semibold text-slate-500 tracking-wider uppercase">核心入口</h2>
				<div class="space-y-3">
					<a href="/projects" class="block p-4 rounded-2xl border border-slate-100 bg-slate-50 hover:bg-white hover:border-blue-200 transition-colors">
						<div class="font-semibold">作品集</div>
						<div class="text-sm text-slate-500">重点案例与项目成果</div>
					</a>
					<a href="/blog" class="block p-4 rounded-2xl border border-slate-100 bg-slate-50 hover:bg-white hover:border-blue-200 transition-colors">
						<div class="font-semibold">博客</div>
						<div class="text-sm text-slate-500">结构化思考与方法论沉淀</div>
					</a>
					<a href="/about" class="block p-4 rounded-2xl border border-slate-100 bg-slate-50 hover:bg-white hover:border-blue-200 transition-colors">
						<div class="font-semibold">关于</div>
						<div class="text-sm text-slate-500">我的背景与工作方式</div>
					</a>
					<a href="/contact" class="block p-4 rounded-2xl border border-slate-100 bg-slate-50 hover:bg-white hover:border-blue-200 transition-colors">
						<div class="font-semibold">联系</div>
						<div class="text-sm text-slate-500">合作/交流/咨询</div>
					</a>
				</div>
			</section>

			<section class="space-y-4">
				<h2 class="text-sm font-semibold text-slate-500 tracking-wider uppercase">社交与平台</h2>
				<div class="space-y-3">
					<a href="https://github.com/jklop3841" target="_blank" rel="noopener noreferrer" class="block p-4 rounded-2xl border border-slate-100 bg-white hover:border-slate-200 transition-colors">
						<div class="font-semibold">GitHub</div>
						<div class="text-sm text-slate-500">代码与开源项目</div>
					</a>
					<a href="#" class="block p-4 rounded-2xl border border-slate-100 bg-white hover:border-slate-200 transition-colors">
						<div class="font-semibold">Newsletter</div>
						<div class="text-sm text-slate-500">订阅更新（可选）</div>
					</a>
				</div>
			</section>

			<section class="rounded-3xl bg-blue-50 border border-blue-100 p-6 text-center space-y-3">
				<div class="text-sm font-semibold text-blue-700">次级 CTA</div>
				<div class="text-slate-700">如果你有明确需求，欢迎直接邮件沟通。</div>
				<a href="mailto:jklop3841@gmail.com" class="inline-flex items-center justify-center px-6 py-3 rounded-full bg-blue-600 text-white font-bold hover:bg-blue-500 transition-colors">
					发邮件
				</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

